<resources>

    <style name="StyleTitle14" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:fontFamily">@font/montserrat_alternates_semibold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="StyleNavButton" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/StyleTitle14</item>
        <item name="cornerRadius">@dimen/corner_radius_button</item>
    </style>

    <style name="HeaderTitleStyle">
        <item name="android:textSize">@dimen/text_size_header</item>
        <item name="android:fontFamily">@font/montserrat_alternates_semibold</item>
        <item name="android:fontWeight">600</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/plum</item>
        <item name="android:text">@string/categories</item>
    </style>

    <style name="CategoryDescriptionStyle">
        <item name="android:textSize">@dimen/text_size_description</item>
        <item name="android:fontFamily">@font/montserrat_alternates_semibold</item>
        <item name="android:fontWeight">500</item>
        <item name="android:textColor">@color/gray</item>
    </style>

    <style name="CategoryNameStyle">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:fontFamily">@font/montserrat_alternates_semibold</item>
        <item name="android:fontWeight">600</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/plum</item>
    </style>
</resources>
