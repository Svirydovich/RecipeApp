<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/margin_half"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="@dimen/corner_radius_button">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/margin_half"
        android:paddingEnd="@dimen/margin_half"
        android:paddingBottom="@dimen/margin_half">

        <ImageView
            android:id="@+id/ivCategoryImage"
            android:layout_width="match_parent"
            android:layout_height="@dimen/category_icon_layout_height"
            android:contentDescription="@string/category_icon_description"
            android:scaleType="centerCrop"
            tools:src="@drawable/bcg_recipes_list" />

        <TextView
            android:id="@+id/tvCategoryName"
            style="@style/CategoryNameStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_half"
            android:layout_weight="1"
            tools:text="Название категории" />

        <TextView
            android:id="@+id/tvCategoryDescription"
            style="@style/CategoryDescriptionStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_half"
            tools:text="Описание категории" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
